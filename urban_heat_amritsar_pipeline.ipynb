    {
      "cell_type": "code",
      "source": [
        "# Define Amritsar's approximate boundary box (longitude, latitude)\n",
        "amritsar = ee.Geometry.Rectangle([74.78, 31.55, 74.95, 31.70])\n",
        "\n",
        "# Quick visualization to confirm the area looks right\n",
        "Map = geemap.Map(center=[31.63, 74.87], zoom=11)\n",
        "Map.addLayer(amritsar, {'color': 'red'}, 'Amritsar AOI')\n",
        "Map\n"
      ],
      "metadata": {
        "id": "r60bT6-nUzCi"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Get Landsat 8 Land Surface Temperature for a recent clear period (summer, since heat is most visible then)\n",
        "landsat = ee.ImageCollection('LANDSAT/LC08/C02/T1_L2') \\\n",
        "    .filterBounds(amritsar) \\\n",
        "    .filterDate('2024-05-01', '2024-06-15') \\\n",
        "    .filter(ee.Filter.lt('CLOUD_COVER', 20)) \\\n",
        "    .first()\n",
        "\n",
        "# Convert the thermal band to actual temperature in Celsius\n",
        "lst = landsat.select('ST_B10').multiply(0.00341802).add(149.0).subtract(273.15)\n",
        "\n",
        "# Visualize it\n",
        "Map2 = geemap.Map(center=[31.63, 74.87], zoom=11)\n",
        "vis_params = {'min': 25, 'max': 50, 'palette': ['blue', 'yellow', 'orange', 'red']}\n",
        "Map2.addLayer(lst.clip(amritsar), vis_params, 'Land Surface Temp (°C)')\n",
        "Map2.addLayer(amritsar, {'color': 'black'}, 'AOI boundary', False)\n",
        "Map2\n"
      ],
      "metadata": {
        "id": "2KIu7GqhV24o"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "landsat = ee.ImageCollection('LANDSAT/LC08/C02/T1_L2') \\\n",
