    {
      "cell_type": "code",
      "source": [
        "landsat = ee.ImageCollection('LANDSAT/LC08/C02/T1_L2') \\\n",
        "    .filterBounds(amritsar) \\\n",
        "    .filterDate('2024-05-01', '2024-06-15') \\\n",
        "    .filter(ee.Filter.lt('CLOUD_COVER', 20))\n",
        "\n",
        "print(\"Number of images found:\", landsat.size().getInfo())\n"
      ],
      "metadata": {
        "id": "wpubEFsoXSNQ"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Get the actual temperature data\n",
        "landsat_median = landsat.median()\n",
        "lst = landsat_median.select('ST_B10').multiply(0.00341802).add(149.0).subtract(273.15)\n",
        "\n",
        "# Check the actual min/max temperature values found\n",
        "stats = lst.reduceRegion(reducer=ee.Reducer.minMax(), geometry=amritsar, scale=100)\n",
        "print(\"Temperature range:\", stats.getInfo())\n",
        "\n",
        "# Render in a brand new map object\n",
        "heat_map = geemap.Map(center=[31.63, 74.87], zoom=12)\n",
        "vis_params = {'min': 25, 'max': 50, 'palette': ['blue', 'yellow', 'orange', 'red']}\n",
        "heat_map.addLayer(lst.clip(amritsar), vis_params, 'LST Amritsar')\n",
        "heat_map\n"
      ],
      "metadata": {
        "id": "mCYS-eeVXpoG"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "heat_map = geemap.Map(center=[31.63, 74.87], zoom=12)\n",
        "vis_params = {'min': 34, 'max': 57, 'palette': ['blue', 'green', 'yellow', 'orange', 'red']}\n",
        "heat_map.addLayer(lst.clip(amritsar), vis_params, 'LST Amritsar')\n",
        "heat_map\n"
      ],
      "metadata": {
        "id": "4D1MP2UZX2wG"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Use the same Landsat collection, but now extract the bands needed for NDVI\n",
        "# Landsat 8: Band 5 = Near Infrared (NIR), Band 4 = Red\n",
        "ndvi_image = landsat_median.normalizedDifference(['SR_B5', 'SR_B4']).rename('NDVI')\n",
        "\n",
        "# Check NDVI range (should be roughly -1 to 1; vegetation is usually 0.2 to 0.8)\n",
        "ndvi_stats = ndvi_image.reduceRegion(reducer=ee.Reducer.minMax(), geometry=amritsar, scale=100)\n",
        "print(\"NDVI range:\", ndvi_stats.getInfo())\n",
        "\n",
        "# Visualize it: brown/red = bare soil or built-up, green = vegetation\n",
        "ndvi_map = geemap.Map(center=[31.63, 74.87], zoom=12)\n",
        "ndvi_vis = {'min': -0.2, 'max': 0.6, 'palette': ['brown', 'yellow', 'lightgreen', 'darkgreen']}\n",
        "ndvi_map.addLayer(ndvi_image.clip(amritsar), ndvi_vis, 'NDVI Amritsar')\n",
        "ndvi_map\n"
      ],
      "metadata": {
        "id": "eB-hP-p8YcKz"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Combine LST and NDVI into one image with two bands\n",
        "combined = lst.rename('LST').addBands(ndvi_image)\n",
        "\n",
        "# Sample many random points across Amritsar to build a dataset\n",
        "sample_points = combined.sample(region=amritsar, scale=100, numPixels=2000, geometries=True)\n",
        "\n",
        "# Convert to a Pandas dataframe for easy analysis\n",
        "import pandas as pd\n",
        "sample_list = sample_points.getInfo()['features']\n",
        "data = [feat['properties'] for feat in sample_list]\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "print(df.head())\n",
        "print(\"\\nCorrelation between NDVI and LST:\")\n",
        "print(df['NDVI'].corr(df['LST']))"
      ],
      "metadata": {
        "id": "0Wf81KICa-dU"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ESA WorldCover gives pre-classified land cover (built-up, cropland, vegetation, water, etc.)\n",
        "worldcover = ee.ImageCollection('ESA/WorldCover/v200').first()\n",
        "\n",
        "# Built-up class in WorldCover is coded as value 50\n",
        "built_up = worldcover.eq(50).rename('Built_up')\n",
        "\n",
        "# Visualize where built-up areas are\n",
        "built_map = geemap.Map(center=[31.63, 74.87], zoom=12)\n",
        "built_map.addLayer(worldcover.clip(amritsar), {}, 'Land Cover')\n",
        "built_map.addLayer(built_up.clip(amritsar).selfMask(), {'palette': ['red']}, 'Built-up areas')\n",
        "built_map"
      ],
      "metadata": {
        "id": "svCpUxCbb-9P"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
